# Supabase project credentials
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM backend (deepseek | gemini | ollama). Default: deepseek.
# DeepSeek path uses a per-print picker (pro for substantive bills, flash
# for procedural docs); see supagraf/enrich/print_unified.py:pick_model.
SUPAGRAF_LLM_BACKEND=deepseek
SUPAGRAF_LLM_MODEL_PRO=deepseek-v4-pro
SUPAGRAF_LLM_MODEL_FLASH=deepseek-v4-flash
# SUPAGRAF_LLM_MODEL=  # override: forces a single model name, bypassing picker
SUPAGRAF_LLM_TIMEOUT_S=300

# Legacy local backend (uncomment + set SUPAGRAF_LLM_BACKEND=ollama):
# SUPAGRAF_LLM_MODEL=gemma4:e4b

# Optional: legacy heavy OCR backend (PaddleOCR-VL-1.5)
# Default PDF path uses pymupdf + tesseract (Polish). Enable paddle only if
# layout-aware multi-column OCR is genuinely needed.
# SUPAGRAF_PDF_BACKEND=paddle
