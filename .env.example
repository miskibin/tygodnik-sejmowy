# Supabase project credentials
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ollama LLM (default model for enrichers)
SUPAGRAF_LLM_MODEL=gemma4:e4b
SUPAGRAF_LLM_TIMEOUT_S=300

# Optional: legacy heavy OCR backend (PaddleOCR-VL-1.5)
# Default PDF path uses pymupdf + tesseract (Polish). Enable paddle only if
# layout-aware multi-column OCR is genuinely needed.
# SUPAGRAF_PDF_BACKEND=paddle
